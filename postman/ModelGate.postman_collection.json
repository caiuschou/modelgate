{
  "info": {
    "_postman_id": "d4ddf174-c968-4f6e-89ba-d1224f93e865",
    "name": "ModelGate Local",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Local debugging collection for ModelGate MVP endpoints."
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/healthz",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "healthz"
          ]
        },
        "description": "Check whether server is running."
      },
      "response": []
    },
    {
      "name": "Chat Completions (non-stream)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{apiKey}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"model\": \"{{model}}\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Hello from Postman\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/chat/completions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "chat",
            "completions"
          ]
        },
        "description": "Proxy request to upstream OpenAI chat completions."
      },
      "response": []
    },
    {
      "name": "Chat Completions (stream=true)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{apiKey}}",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "text/event-stream",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"model\": \"{{model}}\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Tell me a short poem\"\n    }\n  ],\n  \"stream\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/chat/completions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "chat",
            "completions"
          ]
        },
        "description": "SSE streaming response (in Postman may appear chunked)."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "apiKey",
      "value": "mg-local-token"
    },
    {
      "key": "model",
      "value": "gpt-4.1"
    }
  ]
}

